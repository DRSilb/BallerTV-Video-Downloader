{
  "name": "Baller TV Video Downloader",
  "version": "1.0",
  "manifest_version": 3,
  "description": "Finds and downloads the clipping_file_url on BallerTV.",
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_title": "Download Video",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "{53da0134-becd-4bb8-9fc3-1edecdefef06}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}